{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "version": "0.1.0",
  "name": "Cabal",
  "scopeName": "source.cabal",
  "patterns": [
    { "include": "#comments" },
    { "include": "#sections" },
    { "include": "#field_names" },
    { "include": "#booleans" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#conditionals" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "begin": "--",
          "end": "$",
          "name": "comment.line.double-dash.cabal"
        }
      ]
    },
    "sections": {
      "patterns": [
        {
          "match": "^(library|executable|test-suite|benchmark|flag|source-repository-package|common|legacy-library)\\b\\s*(.*)$",
          "captures": {
            "1": { "name": "keyword.control.section.cabal" },
            "2": { "name": "entity.name.section.cabal" }
          }
        }
      ]
    },
    "field_names": {
      "patterns": [
        {
          "match": "^\\s*([a-zA-Z][-a-zA-Z0-9]*)\\s*(:)\\s*(?=\\S)",
          "captures": {
            "1": { "name": "keyword.other.field.cabal" },
            "2": { "name": "punctuation.separator.key-value.cabal" }
          }
        }
      ]
    },
    "booleans": {
      "patterns": [
        {
          "match": "\\b(True|False)\\b",
          "name": "constant.language.boolean.cabal"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "begin": "\"",
          "end": "\"",
          "name": "string.quoted.double.cabal",
          "patterns": [
            {
              "match": "\\\\.",
              "name": "constant.character.escape.cabal"
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "match": "\\b[0-9]+(\\.[0-9]+)?\\b",
          "name": "constant.numeric.cabal"
        }
      ]
    },
    "conditionals": {
      "patterns": [
        {
          "match": "\\b(if|else|then|impl|os|arch|compiler)\\b",
          "name": "keyword.control.conditional.cabal"
        },
        {
          "match": "\\bflag\\b",
          "name": "keyword.other.flag.cabal"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "match": "&&|\\|\\||!",
          "name": "keyword.operator.logical.cabal"
        }
      ]
    }
  }
}